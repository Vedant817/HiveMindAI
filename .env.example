# App stack: free, azure, or local
APP_STACK=free

# LLM provider: auto, openrouter, azure, or none
LLM_PROVIDER=auto

# OpenRouter free/local testing
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-coder:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=HiveMindAI
LLM_REQUEST_TIMEOUT_SECONDS=20

# Azure OpenAI
AZURE_OPENAI_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# Runtime behavior
SWARM_STRICT_INTEGRATIONS=false
SWARM_ENABLE_LOCAL_FALLBACKS=true
TASK_QUEUE_NAME=task-queue
COMPLETIONS_QUEUE_NAME=completions
SWARM_DEFAULT_GOAL=Build a project dashboard before Friday
DEBATE_PERSONAS_JSON=
DEMO_DEFAULTS_FILE=config/demo_defaults.json
DEMO_DEFAULT_GOAL=
DEMO_DEFAULT_TRANSCRIPT=
DEMO_DEFAULT_DEBATE_QUESTION=
CONFIDENCE_THRESHOLD=0.90
MEETING_CONFIDENCE=0.94
MEETING_REVIEW_CONFIDENCE=0.88
EXECUTOR_CONFIDENCE_FLOOR=0.65
EXECUTOR_CONFIDENCE_CAP=0.98
PLANNER_DEFAULT_CONFIDENCE=0.95

# Free cloud stack
MONGODB_URI=
MONGODB_DATABASE=hivemindai
REDIS_URL=

# Azure Cache for Redis
# REDIS_URL=redis://localhost:6379

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=

# Azure Cosmos DB
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=swarm

# Azure AI Search
SEARCH_ENDPOINT=
SEARCH_KEY=
SEARCH_INDEX=knowledge

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Azure Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=
SENDER_EMAIL=
STAKEHOLDER_EMAIL=

# Jira
JIRA_DOMAIN=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_DONE_STATUS=Done
JIRA_IN_PROGRESS_STATUS=In Progress
JIRA_FAILED_STATUS=Failed

# Azure DevOps
AZURE_DEVOPS_ORG_URL=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# Microsoft Teams / Slack
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# App
APP_BASE_URL=http://localhost:8000
APP_HOST=127.0.0.1
APP_PORT=8000
LOCAL_STATE_DIR=local_state
