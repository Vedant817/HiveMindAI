# Free/local test mode.
# Add only OPENROUTER_API_KEY to use a free OpenRouter model.

APP_STACK=free
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-coder:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=HiveMindAI
LLM_REQUEST_TIMEOUT_SECONDS=20

SWARM_STRICT_INTEGRATIONS=false
SWARM_ENABLE_LOCAL_FALLBACKS=true
TASK_QUEUE_NAME=task-queue
COMPLETIONS_QUEUE_NAME=completions
SWARM_DEFAULT_GOAL=Build a project dashboard before Friday
DEMO_DEFAULTS_FILE=config/demo_defaults.json
CONFIDENCE_THRESHOLD=0.90
MEETING_CONFIDENCE=0.94
MEETING_REVIEW_CONFIDENCE=0.88
EXECUTOR_CONFIDENCE_FLOOR=0.65
EXECUTOR_CONFIDENCE_CAP=0.98
PLANNER_DEFAULT_CONFIDENCE=0.95

# Free cloud services:
# MongoDB Atlas free tier connection string.
MONGODB_URI=
MONGODB_DATABASE=hivemindai

# Upstash Redis free tier connection string. Use the rediss:// URL.
REDIS_URL=
APP_BASE_URL=http://localhost:8000
APP_HOST=127.0.0.1
APP_PORT=8000
LOCAL_STATE_DIR=local_state
